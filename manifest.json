{
  "manifest_version": 3,
  "name": "Agentic AI Conversation",
  "version": "1.1",
  "description": "Multi-AI discussion workspace in your sidebar",
  "permissions": ["sidePanel", "storage", "tabs", "scripting"],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://x.com/*",
    "*://grok.com/*",
    "*://www.perplexity.ai/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "https://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "action": {
    "default_title": "Open Agentic AI Conversation",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
