{
  "manifest_version": 3,
  "name": "Agentic AI Conversation",
  "version": "1.2.1",
  "description": "Multi-AI discussion workspace, bridge runs in background",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://x.com/*",
    "*://grok.com/*",
    "*://www.perplexity.ai/*",
    "*://www.kimi.com/*",
    "*://*.kimi.com/*",
    "*://chat.z.ai/*",
    "*://www.genspark.ai/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "https://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "action": {
    "default_title": "Council of AI - Click to open",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "web_accessible_resources": [{
    "resources": ["web-ui.html", "style.css", "script.js", "platforms.js", "syntax-highlight.js", "lucide.min.js", "favicon.ico"],
    "matches": ["<all_urls>"]
  }],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}